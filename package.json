{
  "name": "bom-change-intelligence-layer",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:lint": "npm --prefix frontend run lint",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "backend:dev": "backend/.venv/bin/uvicorn app.main:app --reload --app-dir backend",
    "backend:test": "backend/.venv/bin/pytest",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "cd backend && .venv/bin/alembic upgrade head",
    "db:reset-data": "cd backend && .venv/bin/python -m app.scripts.reset_dev_data",
    "prod:build": "docker compose --env-file .env.production -f docker-compose.prod.yml build",
    "prod:up": "docker compose --env-file .env.production -f docker-compose.prod.yml up -d",
    "prod:down": "docker compose --env-file .env.production -f docker-compose.prod.yml down",
    "prod:logs": "docker compose --env-file .env.production -f docker-compose.prod.yml logs -f"
  }
}
