APP_NAME=AI-Assisted BOM Change Intelligence Layer
APP_VERSION=0.1.0
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://bom_tracker:bom_tracker_password@localhost:5432/bom_tracker
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
JWT_SECRET_KEY=change-this-dev-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
UPLOAD_DIRECTORY=uploads
MAX_UPLOAD_SIZE_MB=25
AUTH_RATE_LIMIT_PER_MINUTE=10
MUTATION_RATE_LIMIT_PER_MINUTE=120
